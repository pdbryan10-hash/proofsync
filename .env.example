# ---------------------------------------------------------------------------
# ProofSync — environment configuration
# Copy to `.env` for local development. NEVER commit real secrets.
# ---------------------------------------------------------------------------

# Database — ProofSync's own store (job mirror, sync ledger, exceptions, audit).
# MongoDB (Atlas): prisma/schema.prisma has provider = "mongodb".
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/see_cafm_sync?retryWrites=true&w=majority"

# How the connectors reach the source and target systems:
#   mock — this same database stands in for both systems (the seeded product tour).
#   demo — two SEPARATE databases stand in for two SEPARATE systems, reached over
#          a simulated login. Drives the /demo live console. See docs/DEMO.md.
#   live — the real provider APIs.
INTEGRATION_MODE=mock

# --- Joblogic (source system) -----------------------------------------------
# TODO: supply real values from the contractor's Joblogic account before going live.
JOBLOGIC_API_BASE_URL=
JOBLOGIC_API_KEY=
JOBLOGIC_TENANT_ID=
JOBLOGIC_WEBHOOK_SECRET=

# --- Concerto (target system) ----------------------------------------------
# TODO: supply real values from the client's Concerto environment.
CONCERTO_API_BASE_URL=
CONCERTO_API_KEY=
CONCERTO_CLIENT_ID=
CONCERTO_CLIENT_SECRET=

# --- Live sync demo (/demo) -------------------------------------------------
# Master switch. Without this, /demo and every /api/demo/* route return 404.
# Needs INTEGRATION_MODE=demo to actually sync. The demo routes refuse to run at
# all while INTEGRATION_MODE=live, so fabricated jobs can never reach a real CAFM.
DEMO_MODE=0

# Seconds between sync beats. NOTE: Vercel Cron's floor is one minute, so the 30s
# cadence is delivered by callers pinging /api/demo/tick while the server claims
# each beat atomically. /api/cron/demo-tick is a 1-minute headless backstop.
DEMO_TICK_SECONDS=30

# Maximum new jobs the stand-in source system creates per beat.
DEMO_DRIP_PER_TICK=2

# How the connectors reach the two stand-in systems:
#   direct  — read/write their databases. Fast, robust, runs anywhere. The login
#             lifecycle is modelled but the access method is NOT proved.
#   browser — drive a real Chromium through both systems' actual screens: fill the
#             login form, read the rendered job, type into the target's form, click
#             Save, re-read to verify. This is the proof for a vendor with no API.
#
# *** browser CANNOT run on Vercel *** — there is no Chromium in the serverless
# runtime. It is a local (or containerised worker) transport. Keep Vercel on direct.
# Requires: npx playwright install chromium
DEMO_TRANSPORT=direct

# Where the stand-in systems' UIs are served — the browser transport points
# Chromium at this, so it must be reachable from the machine running the browser.
DEMO_BASE_URL=http://localhost:3000

# Show the browser window. Headed is the point of a live demo; set to 1 to hide it
# (screenshots are still captured to the ledger either way).
# DEMO_HEADLESS=1

# Syncs attempted per beat. Defaults to 8 (direct) or 2 (browser) — a browser-driven
# sync takes 10-20s against a 60s route budget. Overflow stays PENDING for next beat.
# DEMO_MAX_SYNCS_PER_TICK=

# The two stand-in systems' databases. By default these are separate databases on
# the same cluster as DATABASE_URL, so the demo needs no extra infrastructure.
# Set the *_URL vars to put either system on a wholly separate cluster.
DEMO_JOBLOGIC_DB_NAME=proofsync_demo_joblogic
DEMO_CONCERTO_DB_NAME=proofsync_demo_concerto
# DEMO_JOBLOGIC_DB_URL=
# DEMO_CONCERTO_DB_URL=

# --- Scheduled jobs ---------------------------------------------------------
# Protects /api/cron/* and the demo's destructive routes. Vercel Cron sends this
# automatically as `Authorization: Bearer <CRON_SECRET>`.
# WARNING: if unset, those endpoints are UNAUTHENTICATED. Set it in production.
CRON_SECRET=

# --- Value-calculation tuning ----------------------------------------------
# Estimated minutes of duplicated admin removed per successfully synced job.
ESTIMATED_MANUAL_MINUTES_PER_JOB=15

# --- Public (safe to expose to the browser — NEVER put secrets here) --------
NEXT_PUBLIC_APP_NAME="ProofSync"
