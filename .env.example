# ---------------------------------------------------------------------------
# SEE CAFM Sync — environment configuration
# Copy to `.env` for local development. NEVER commit real secrets.
# ---------------------------------------------------------------------------

# Database
# Local demo (default): SQLite file — zero external services required.
DATABASE_URL="file:./dev.db"
# Production (Vercel): switch prisma/schema.prisma provider to "postgresql"
# and point this at Vercel Postgres / Neon, e.g.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/see_cafm_sync?sslmode=require"

# Integration mode: "mock" (demo, default) or "live" (real APIs)
INTEGRATION_MODE=mock

# --- Joblogic (source system) -----------------------------------------------
# TODO: supply real values from SEE's Joblogic account before switching to live.
JOBLOGIC_API_BASE_URL=
JOBLOGIC_API_KEY=
JOBLOGIC_TENANT_ID=
JOBLOGIC_WEBHOOK_SECRET=

# --- Concerto (target system) ----------------------------------------------
# TODO: supply real values from the client's Concerto environment.
CONCERTO_API_BASE_URL=
CONCERTO_API_KEY=
CONCERTO_CLIENT_ID=
CONCERTO_CLIENT_SECRET=

# --- Scheduled polling ------------------------------------------------------
# Secret protecting the 30-minute completion poller (/api/cron/poll-completions).
# Vercel Cron sends this automatically as `Authorization: Bearer <CRON_SECRET>`.
# Leave unset locally (endpoint is then open in demo mode).
CRON_SECRET=

# --- Value-calculation tuning ----------------------------------------------
# Estimated minutes of duplicated admin removed per successfully synced job.
ESTIMATED_MANUAL_MINUTES_PER_JOB=15

# --- Public (safe to expose to the browser — NEVER put secrets here) --------
NEXT_PUBLIC_APP_NAME="ProofSync"
